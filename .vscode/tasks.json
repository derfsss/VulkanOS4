{
  "tasks": [
    {
      "type": "shell",
      "label": "docker-build",
      "command": "make",
      "args": ["docker-build"],
      "options": {
        "shell": {
          "executable": "wsl.exe",
          "shellArgs": ["-e", "bash", "-c"]
        },
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    }
  ]
}
